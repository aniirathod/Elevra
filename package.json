{
  "name": "Resume Analyiser and builder",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:docker": "bash ./infra/scripts/start.sh",
    "stop:docker": "bash ./infra/scripts/stop.sh",
    "clean:docker": "bash ./infra/scripts/clean.sh",
    "logs:docker": "bash ./infra/scripts/logs.sh",
    "rebuild:docker": "bash ./infra/scripts/rebuild.sh"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.2.0",
  "workspaces": [
    "apps/*",
    "apps/services/*",
    "packages/*"
  ]
}
